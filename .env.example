# Database (PostgreSQL — use Neon free tier for local + Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth (change in production)
JWT_SECRET="change-me-to-a-random-secret-in-production"

# AI Providers (optional — falls back to enhanced mock when unset)
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="dall-e-3"

# Replicate for image-to-video (optional)
REPLICATE_API_TOKEN=""
REPLICATE_VIDEO_MODEL="stability-ai/stable-video-diffusion-img2vid-xt"

# Storage
STORAGE_DIR="./storage"

# Ocean Engine 巨量审核（暂无 API 文档时使用 mock）
OCEAN_ENGINE_USE_HTTP="false"
OCEAN_ENGINE_ACCESS_TOKEN=""
OCEAN_ENGINE_API_BASE="https://open.oceanengine.com/open_api"
OCEAN_ENGINE_ADVERTISER_ID=""
