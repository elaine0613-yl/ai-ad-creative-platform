generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  plan         String     @default("free")
  credits      Int        @default(100)
  totalCredits Int        @default(100)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  materials    Material[]
  tasks        Task[]
  campaigns    Campaign[]
}

model Sku {
  id        String   @id @default(cuid())
  skuCode   String   @unique
  name      String
  category  String
  tags      String   @default("[]")
  price     Float
  imageUrl  String?
  promoPool String?
  stock     Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([promoPool, status])
}

model Campaign {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId      String
  stage           String   @default("intent")
  userIntent      String   @default("")
  requirementJson String   @default("{}")
  selectedSkuId   String?
  recommendationsJson String @default("[]")
  creativeJson    String   @default("{}")
  messagesJson    String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  materials       Material[]

  @@index([userId, stage])
}

model Material {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId           String?
  campaign             Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  name                 String
  type                 String
  url                  String
  thumbnailUrl         String?
  width                Int       @default(800)
  height               Int       @default(800)
  tags                 String    @default("[]")
  version              Int       @default(1)
  complianceStatus     String?
  lifecycleStatus      String    @default("draft")
  oceanEngineAuditId   String?
  oceanEngineAuditJson String    @default("{}")
  rejectReason         String?
  metadata             String    @default("{}")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([lifecycleStatus])
}

model Task {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         String
  mode         String
  status       String    @default("queued")
  progress     Int       @default(0)
  totalCount   Int       @default(1)
  successCount Int       @default(0)
  failCount    Int       @default(0)
  payload      String    @default("{}")
  result       String    @default("{}")
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([userId, status])
}
